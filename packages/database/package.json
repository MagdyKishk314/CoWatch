{
  "name": "@cowatch/database",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint @cowatch/database (eslint flat-config pending)\"",
    "test": "echo \"(no tests in @cowatch/database)\"",
    "clean": "rimraf dist .turbo generated *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "prisma": "^6.2.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^22.10.0"
  }
}
