# =============================================================================
# Cowatch — Root Environment Template (.env.example)
# =============================================================================
# Purpose : Documented superset of EVERY environment variable the Cowatch
#           platform will consume. This is the configuration CONTRACT.
# Status  : Planning (Phase 0 — Architecture). FORWARD-LOOKING SKELETON.
# Owner   : DevOps Engineer
# Last updated: 2026-06-27
#
# -----------------------------------------------------------------------------
# PLANNING NOTE — the apps referenced here DO NOT EXIST YET.
# This file is a planning artifact that pins the env-var surface so that
# `packages/shared/config` (the single typed config module) and the Docker
# compose stack can be built against a stable contract. Values below are
# PLACEHOLDERS — never commit real secrets.
#
# Canon ........... ../context/architecture.md  (§8 Auth, §10 Non-negotiables)
# Deployment doc .. docs/DEPLOYMENT.md           (§5 Env & Config, §5.2 matrix)
# Docker stack .... docker/docker-compose.yml, docker/README.md
#
# CONVENTIONS
#   * 12-factor: ALL configuration comes from the environment.
#   * `packages/shared/config` validates these at boot (Zod / class-validator)
#     and FAILS FAST (non-zero exit) on a missing/invalid REQUIRED var.
#   * CI asserts every key referenced by the config schema exists HERE.
#   * Secrets are NEVER committed. Real values are injected at runtime:
#       - local : docker/.env.local (git-ignored)            -> env_file
#       - vps   : Docker secrets (/run/secrets/*) or SOPS-decrypted .env
#       - vercel: Vercel encrypted env vars (web/landing + edge transport)
#       - prod  : cloud secret manager (Vault / AWS SM / Doppler)
#   * Time is UTC everywhere. All containers run TZ=UTC.
#
# LEGEND
#   [secret]   never log, never bake into an image, runtime-inject only
#   [required] config module fails fast if missing in the listed scope
#   [optional] has a safe default; may be omitted
#   scope: which service(s)/target(s) read it
# =============================================================================


# -----------------------------------------------------------------------------
# 0. RUNTIME / GLOBAL
# -----------------------------------------------------------------------------
# scope: all · [required]
# development | production  (drives logging, error verbosity, cookie flags)
NODE_ENV=development

# scope: all · [required]
# Always UTC. Containers are pinned to this; clients localize for display only.
TZ=UTC

# scope: all · [required]
# Public origin of the platform. Drives CORS allowlist defaults + cookie domain.
# local   -> http://localhost:5173
# prod    -> https://cowatch.app
APP_BASE_URL=http://localhost:5173

# scope: web/desktop · [required]
# Where clients send REST + WS traffic. MUST include the /api/v1 base path.
# local   -> http://localhost:3000/api/v1
# prod    -> https://api.cowatch.app/api/v1
API_BASE_URL=http://localhost:3000/api/v1

# scope: web/desktop · [required]
# WebSocket origin for the realtime transport (native-ws). Often same host as API.
# local   -> ws://localhost:3000
# prod    -> wss://api.cowatch.app
WS_BASE_URL=ws://localhost:3000


# -----------------------------------------------------------------------------
# 1. SERVICE PORTS (host-published in local; internal-only in vps/prod)
# -----------------------------------------------------------------------------
# scope: server · [required]
SERVER_PORT=3000
# scope: web (Vite dev / nginx) · [optional]
WEB_PORT=5173
# scope: landing (Vite dev / nginx) · [optional]
LANDING_PORT=4321
# scope: mongo · [optional] (NOT published to host in vps/prod)
MONGO_PORT=27017
# scope: minio API · [optional]
MINIO_API_PORT=9000
# scope: minio console · [optional] (bastion/SSH-tunnel only in prod)
MINIO_CONSOLE_PORT=9001
# scope: livekit signaling (WS/HTTP) · [optional]
LIVEKIT_PORT=7880
# scope: livekit TCP fallback for WebRTC · [optional]
LIVEKIT_TCP_PORT=7881
# scope: livekit RTP/UDP media range start · [optional]
LIVEKIT_RTP_UDP_START=50000
# scope: livekit RTP/UDP media range end · [optional]
LIVEKIT_RTP_UDP_END=60000
# scope: redis · [optional]
REDIS_PORT=6379


# -----------------------------------------------------------------------------
# 2. REALTIME TRANSPORT (ADR-004 / canon §5)
# -----------------------------------------------------------------------------
# scope: server + clients · [required]
# Selects the replaceable transport adapter. Apps are UNAWARE of the choice.
#   native-ws       -> VPS / production default (stateful WS in the Nest process)
#   livekit-data    -> (future) reuse LiveKit data channel as transport
#   durable-object  -> (future) Cloudflare DO per-room authority at the edge
#   vercel-edge     -> (future) serverless bridge for Vercel CDN deploys
REALTIME_TRANSPORT=native-ws

# scope: server · [optional]
# Server heartbeat cadence for `playback:sync` (canon §7 mandates 2000 ms).
REALTIME_SYNC_HEARTBEAT_MS=2000

# scope: server · [optional]
# Reconnection backoff (transport owns exponential backoff + jitter, canon §5).
REALTIME_BACKOFF_BASE_MS=500
REALTIME_BACKOFF_CAP_MS=15000

# scope: server · [optional]
# Resume-buffer depth: how many recent envelopes per room are retained for the
# `resume` handshake replay (in-memory ring locally; Redis stream multi-instance).
REALTIME_RESUME_BUFFER_SIZE=512


# -----------------------------------------------------------------------------
# 3. AUTH / TOKENS (ADR-008 / canon §8)
# -----------------------------------------------------------------------------
# scope: server · [secret][required]
# RS256 keypair (PEM). Access tokens are signed with the PRIVATE key; the PUBLIC
# key is published via JWKS for verification + rotation. Generate locally with
# scripts/gen-keys.sh. Use \n-escaped single-line PEM or a mounted secret file.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# scope: server · [required]
# Key id surfaced in the JWT header + JWKS, enables zero-downtime key rotation.
JWT_KEY_ID=cowatch-key-2026-06

# scope: server · [required] · canon §8 fixed lifetimes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# scope: server · [required]
# JWT registered claims.
JWT_ISSUER=cowatch
JWT_AUDIENCE=cowatch-clients

# scope: server · [required]
# Rotating refresh token cookie — httpOnly, Secure, SameSite=Strict, scoped to
# the /api/v1/auth path (canon §8). Domain is empty for localhost.
# prod -> .cowatch.app
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_NAME=cw_rt
# Set false ONLY for plain-HTTP local dev; MUST be true everywhere with TLS.
REFRESH_COOKIE_SECURE=false

# scope: server · [secret][required]
# Symmetric secret used to HMAC short-lived single-use tokens (email verify,
# password reset). Distinct from the JWT keypair.
TOKEN_HASH_SECRET=replace-with-32-byte-random-hex

# scope: server · [secret][required]
# Pepper applied before bcrypt/argon2 password hashing (defense in depth).
PASSWORD_HASH_PEPPER=replace-with-random-pepper
# argon2id parameters (defaults are sane; tune per host).
PASSWORD_HASH_MEMORY_KIB=19456
PASSWORD_HASH_ITERATIONS=2

# scope: server · [secret][required]
# Encryption key for TOTP shared secrets + recovery codes at rest (2FA).
TOTP_ENCRYPTION_KEY=replace-with-32-byte-base64-key
TOTP_ISSUER=Cowatch


# -----------------------------------------------------------------------------
# 4. GOOGLE OAUTH (canon §8 — /api/v1/auth/oauth/google)
# -----------------------------------------------------------------------------
# scope: server · [secret][required]
GOOGLE_OAUTH_CLIENT_ID=replace.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace-google-oauth-secret
# Must match the redirect URI registered in the Google Cloud console.
# local -> http://localhost:3000/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback


# -----------------------------------------------------------------------------
# 5. DATABASE — MongoDB via Prisma (ADR-003 / canon §4)
# -----------------------------------------------------------------------------
# scope: server · [secret][required]
# Prisma requires a REPLICA SET for transactions; local compose initiates `rs0`.
# Format: mongodb://<user>:<pass>@<host>:<port>/<db>?replicaSet=<rs>&authSource=admin
# local -> mongodb://cowatch:cowatch@mongo:27017/cowatch?replicaSet=rs0&authSource=admin
DATABASE_URL=mongodb://cowatch:cowatch@mongo:27017/cowatch?replicaSet=rs0&authSource=admin

# scope: mongo container bootstrap · [secret][required]
# Root credentials the mongo image creates on first boot (compose env wiring).
MONGO_INITDB_ROOT_USERNAME=cowatch
MONGO_INITDB_ROOT_PASSWORD=cowatch
MONGO_INITDB_DATABASE=cowatch
# Replica-set name; the rs-init script runs `rs.initiate` for this.
MONGO_REPLICA_SET=rs0


# -----------------------------------------------------------------------------
# 6. OBJECT STORAGE — MinIO (ADR-009 / canon §10)
# -----------------------------------------------------------------------------
# scope: server/minio · [secret][required]
# Root creds the MinIO container creates on first boot. The SERVER uses a SCOPED
# service account (least privilege, D4) — clients NEVER receive these; uploads
# and downloads flow through pre-signed URLs minted by StorageModule.
MINIO_ROOT_USER=cowatch
MINIO_ROOT_PASSWORD=cowatch-minio-secret

# scope: server · [required]
# Internal endpoint the server talks to (no scheme = host:port).
# local -> minio:9000
MINIO_ENDPOINT=minio:9000
# Use TLS to MinIO (false for local plain HTTP).
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
# Public base URL stamped into pre-signed URLs handed to clients.
# local -> http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000

# scope: server · [required] — the five canonical buckets (DEPLOYMENT §4.2)
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_ROOM_ASSETS=room-assets
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_BUCKET_CACHES=caches


# -----------------------------------------------------------------------------
# 7. VOICE / VIDEO — LiveKit (ADR-005)
# -----------------------------------------------------------------------------
# scope: server/clients · [required]
# Signaling URL clients connect to. The SERVER mints per-room access JWTs.
# local -> ws://localhost:7880    prod -> wss://livekit.cowatch.app
LIVEKIT_URL=ws://localhost:7880

# scope: server/livekit · [secret][required]
# API key/secret pair the server uses to sign LiveKit room tokens. MUST match
# the keys configured in docker/livekit/livekit.yaml.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace-with-livekit-api-secret


# -----------------------------------------------------------------------------
# 8. REDIS (optional locally; REQUIRED for multi-instance server — D3)
# -----------------------------------------------------------------------------
# scope: server · [optional locally / required vps+prod multi-instance]
# Backs realtime pub/sub fan-out, the resume buffer, rate-limit counters, and
# ephemeral presence. A single server instance runs WITHOUT this (in-process).
# local -> redis://redis:6379
REDIS_URL=redis://redis:6379
# scope: redis · [secret][optional] — set in vps/prod; empty for local.
REDIS_PASSWORD=


# -----------------------------------------------------------------------------
# 9. SECURITY / CORS / RATE LIMITING (canon §10)
# -----------------------------------------------------------------------------
# scope: server · [required]
# Comma-separated strict origin allowlist for CORS. NO wildcards in prod.
CORS_ALLOWLIST=http://localhost:5173,http://localhost:4321

# scope: server · [optional]
# Per-IP and per-user token buckets on auth + write endpoints.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_IP=100
RATE_LIMIT_MAX_PER_USER=300
# Tighter bucket specifically for /api/v1/auth/* (brute-force resistance).
RATE_LIMIT_AUTH_MAX_PER_IP=20

# scope: server · [secret][required]
# Secret for double-submit CSRF token on cookie-auth mutations.
CSRF_SECRET=replace-with-csrf-secret

# scope: server · [optional]
# Comma-separated trusted proxy hops so the real client IP survives Traefik.
TRUSTED_PROXIES=127.0.0.1


# -----------------------------------------------------------------------------
# 10. EMAIL / SMTP (verification + password reset — vps/prod)
# -----------------------------------------------------------------------------
# scope: server · [secret][required in vps/prod]
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true
SMTP_FROM_EMAIL=no-reply@cowatch.app
SMTP_FROM_NAME=Cowatch


# -----------------------------------------------------------------------------
# 11. MEDIA PROVIDER — YouTube (first provider, SPEC)
# -----------------------------------------------------------------------------
# scope: server · [secret][optional]
# YouTube Data API key for metadata/title/duration lookups + search.
YOUTUBE_API_KEY=


# -----------------------------------------------------------------------------
# 12. OBSERVABILITY (canon §10 / DEPLOYMENT §8)
# -----------------------------------------------------------------------------
# scope: all · [optional]
# pino. Local dev sets LOG_PRETTY=true; prod emits raw JSON.
LOG_LEVEL=debug
LOG_PRETTY=true

# scope: all · [optional, vps/prod]
# OpenTelemetry OTLP collector endpoint (traces + metrics).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=cowatch-server

# scope: all · [secret][optional, vps/prod]
# Sentry error tracking. Source maps uploaded at build time, NOT shipped.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development


# -----------------------------------------------------------------------------
# 13. BUILD / IMAGE PROVENANCE (set by CI — non-secret build args)
# -----------------------------------------------------------------------------
# scope: build · [optional]
# Stamped into OCI image labels (DEPLOYMENT §2.1). Do not set by hand locally.
GIT_SHA=local-dev
IMAGE_VERSION=0.0.0-dev
IMAGE_CREATED=
# Container registry namespace for pushed images (CI only).
IMAGE_REGISTRY=ghcr.io/cowatch
