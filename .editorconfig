# Cowatch — EditorConfig (https://editorconfig.org)
# Consistent formatting across all editors/IDEs. Last updated: 2026-06-27.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Markdown — trailing whitespace can be a hard line break; do not trim.
[*.md]
trim_trailing_whitespace = false

# YAML / JSON config
[*.{yml,yaml,json,jsonc}]
indent_size = 2

# Lockfiles and generated content — leave as-is.
[pnpm-lock.yaml]
indent_size = 2
insert_final_newline = false

# Shell scripts
[*.sh]
end_of_line = lf

# Windows batch / PowerShell scripts use CRLF.
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Makefiles require real tabs.
[Makefile]
indent_style = tab
