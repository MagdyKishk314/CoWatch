{
  "$schema": "https://json.schemastore.org/tsconfig",
  "//": "Cowatch shared strict TypeScript base. Extended by every app/package tsconfig. Canon: context/architecture.md. Last updated: 2026-06-27.",
  "compilerOptions": {
    /* Language & module target */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "useDefineForClassFields": true,

    /* Strictness — non-negotiable */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "forceConsistentCasingInFileNames": true,

    /* Decorators — required by NestJS (ADR-002) */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Interop & emit */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "importHelpers": true,
    "skipLibCheck": true,

    /* Diagnostics */
    "pretty": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "out",
    "coverage",
    ".turbo"
  ]
}
